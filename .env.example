# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env file.

# --- PayPal REST app credentials (from developer.paypal.com) ---
# Client ID is public (sent to the browser). Secret is server-side ONLY.
PAYPAL_CLIENT_ID=your-live-or-sandbox-client-id
PAYPAL_CLIENT_SECRET=your-live-or-sandbox-secret

# "sandbox" for testing, "live" for real payments.
PAYPAL_ENV=sandbox

# Currency for donations (ISO 4217), e.g. USD, EUR, GBP.
DONATION_CURRENCY=USD

# Port the server listens on.
PORT=8080
